{
  // Scoped type-check for the LEGO/LDraw core (engine + 3D viewer).
  //
  // The full `web/tsconfig.json` currently has ~34 pre-existing errors in the
  // unrelated `web/src/ui/*` mapping/import files, which is why CI can't gate on
  // it yet. This config covers ONLY the LEGO modules — which are type-clean — so
  // CI can guard them against silent compile-breakage today (ROADMAP.md #1).
  // Widen `include` toward the full project as the ui/* errors get fixed.
  "extends": "./tsconfig.json",
  "include": ["src/engine/**/*.ts", "src/viewer/ldraw/**/*.ts"]
}
